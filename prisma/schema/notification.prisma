model Notification {
  id        String           @id @default(uuid(7))

  userId    String

  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)

  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification")
}
