model StatsCache {
    id String @id @default(uuid(7))

    // Existing metrics
    totalParcels          Int   @default(0)
    totalPendingParcels   Int   @default(0)
    totalCompletedParcels Int   @default(0)
    totalUsers            Int   @default(0)
    totalRevenue          Float @default(0)

    // Time-based metrics
    dailyRevenue   Float @default(0)
    weeklyRevenue  Float @default(0)
    monthlyRevenue Float @default(0)
    dailyParcels   Int   @default(0)
    weeklyParcels  Int   @default(0)
    monthlyParcels Int   @default(0)

    // Rider metrics
    activeRiders Int     @default(0)
    onlineRiders Int     @default(0)
    totalRiders  Int     @default(0)
    topRiderId   String?

    // Customer metrics
    activeCustomers Int @default(0)
    totalCustomers  Int @default(0)

    // Performance metrics
    avgDeliveryTime     Float @default(0) // in hours
    deliverySuccessRate Float @default(0) // percentage

    // Financial metrics
    avgOrderValue   Float @default(0)
    platformRevenue Float @default(0) // 30% of parcel price
    riderPayouts    Float @default(0)
    pendingPayouts  Float @default(0)

    // Growth metrics
    newUsersToday     Int @default(0)
    newUsersThisWeek  Int @default(0)
    newUsersThisMonth Int @default(0)

    updatedAt DateTime @updatedAt

    @@map("stats_cache")
}
